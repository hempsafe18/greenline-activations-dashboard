{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "env": {
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY": "@next_public_clerk_publishable_key"
  },
  "routes": [
    {
      "src": "/clients/(.*)",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate",
        "X-Frame-Options": "DENY",
        "X-Content-Type-Options": "nosniff"
      },
      "dest": "/clients/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
