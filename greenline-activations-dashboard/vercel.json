{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/clients/(.*)",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate",
        "X-Frame-Options": "DENY",
        "X-Content-Type-Options": "nosniff"
      },
      "dest": "/clients/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
